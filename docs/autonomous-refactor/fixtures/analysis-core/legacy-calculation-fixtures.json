  "publicSurfaces": {
    "calculateIndicatorTool": {
      "path": "src/tool/analysis.ts",
      "factory": "createAnalysisTools",
      "toolName": "calculateIndicator",
      "inputShape": {
        "asset": {
          "type": "enum",
          "required": true,
          "values": ["equity", "crypto", "currency", "commodity"]
        },
        "formula": {
          "type": "string",
          "required": true
        },
        "precision": {
          "type": "integer",
          "required": false,
          "min": 0,
          "max": 10,
          "effectiveDefault": 4
        }
      },
      "outputShape": {
        "value": "number | number[] | Record<string, number>",
        "dataRange": "Record<string, { symbol: string; from: string; to: string; bars: number }>"
      }
    },
    "indicatorCalculator": {
      "path": "src/domain/analysis/indicator/calculator.ts",
      "className": "IndicatorCalculator",
      "method": "calculate(formula: string, precision = 4)",
      "outputShape": {
        "value": "number | number[] | Record<string, number>",
        "dataRange": "Record<string, DataSourceMeta>"
      }
    },
    "thinkingCalculateTool": {
      "path": "src/tool/thinking.ts",
      "factory": "createThinkingTools",
      "toolName": "calculate",
      "inputShape": {
        "expression": {
          "type": "string",
          "required": true
        }
      },
      "outputShape": "number"
    },
    "thinkingCalculateFunction": {
      "path": "src/domain/thinking/tools/calculate.tool.ts",
      "functionName": "calculate(expression: string)",
      "outputShape": "number"
    }
  },
