{
  "name": "@openalice/node-bindings-analysis-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenAlice analysis_core Node binding. In-process napi-rs bridge for the Rust parser kernel (per ADR-003) with an opt-in CLI fallback for debug.",
  "license": "AGPL-3.0-only",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build:napi": "node scripts/build-native.mjs",
    "build:napi:release": "OPENALICE_NAPI_PROFILE=release node scripts/build-native.mjs",
    "build:bin": "cargo build --release --bin analysis-core-parse -p analysis-core-node-binding",
    "build:bin:debug": "cargo build --bin analysis-core-parse -p analysis-core-node-binding",
    "test": "node --input-type=module -e \"import('./index.js').then(m => { if (m.bootstrapHealthcheck() !== 'analysis_core:bootstrap') process.exit(1); })\""
  }
}
